{
  "builds": [
    {
      "src": "app/vercel_app.py",
      "use": "@vercel/python",
      "config": {
        "maxLambdaSize": "15mb",
        "installCommand": "pip install -r requirements.txt"
      }
    }
  ],
  "routes": [
    {
      "src": "/static/(.*)",
      "dest": "/static/$1"
    },
    {
      "src": "/(.*)",
      "dest": "app/vercel_app.py"
    }
  ],
  "env": {
    "PYTHON_VERSION": "3.11"
  }
}
