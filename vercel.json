{
  "builds": [
    {
      "src": "FRA_AI_Data/app/vercel_app.py",
      "use": "@vercel/python",
      "config": {
        "maxLambdaSize": "15mb"
      }
    }
  ],
  "routes": [
    {
      "src": "/static/(.*)",
      "dest": "FRA_AI_Data/app/static/$1"
    },
    {
      "src": "/(.*)",
      "dest": "FRA_AI_Data/app/vercel_app.py"
    }
  ]
}
